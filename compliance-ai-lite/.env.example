# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Google Gemini (Required) ───────────────────────────────────────────────────
# Obtain your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Scraper ────────────────────────────────────────────────────────────────────
RBI_CIRCULAR_LIMIT=5
RBI_BASE_URL=https://www.rbi.org.in
SCRAPER_TIMEOUT_SECONDS=10
SCRAPER_USER_AGENT=ComplianceAI-Lite/1.0 (compliance monitoring tool; contact@example.com)

# ── PDF Parser ─────────────────────────────────────────────────────────────────
PDF_DOWNLOAD_TIMEOUT_SECONDS=15
PDF_MAX_TOKENS=8000

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30
